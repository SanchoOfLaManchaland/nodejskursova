{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "testMatch": ["**/*.test.ts"],
  "transform": {},
  "globals": {
    "ts-jest": {
      "tsconfig": "tsconfig.test.json"
    }
  },
  "collectCoverageFrom": ["../src/**/*.ts", "!../src/app.ts", "!**/node_modules/**"],
  "coverageDirectory": "coverage",
  "coveragePathIgnorePatterns": ["/node_modules/"]
}